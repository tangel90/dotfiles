#!/usr/bin/env bash

if [[ $# -ge 1 ]]; then
    selected=$(fd . $@ --type d -d 4 --hidden --follow \
        | awk -F/ '{print NF, $0}' | sort -n -k1,1 -k2 | cut -d' ' -f2- \
        | fzf --tiebreak=length,index)
else
    selected=$(fd . "$HOME" --type d -d 6 --hidden --follow -E "notes/" -E "tmp/" -E ".password-store" -E "queries/" \
        | awk -F/ '{print NF, $0}' | sort -n -k1,1 -k2 | cut -d' ' -f2- \
        | fzf --tiebreak=length,index)
fi

if [[ -z $selected ]]; then
    exit 0
fi

# Resolve session name. If selected is inside a git repo, use the repo root's
# basename so subdirs of the same repo collapse onto one session.
if repo_root=$(git -C "$selected" rev-parse --show-toplevel 2>/dev/null); then
    name_source=$(basename "$repo_root")
else
    repo_root=""
    name_source=$(basename "$selected")
fi
selected_name=$(echo "$name_source" | tr . _)
selected_name=${selected_name%%[_-]*}
tmux_running=$(pgrep tmux)

# OK - tmux is not running
if [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c "$selected"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2> /dev/null; then

    tmux new-session -ds "$selected_name" -c "$selected"
    run_cmd=""
    if [[ -f "$selected/.envrc" ]]; then
        run_cmd=$( (source "$selected/.envrc"; printf '%s\n' "${RUN_COMMAND:-}") )
        if [[ -n $run_cmd ]]; then
          tmux set-environment -t "$selected_name" RUN_COMMAND "$run_cmd"

          run_default_args=$( (source "$selected/.envrc"; printf '%s\n' "${RUN_DEFAULT_ARGS:-}") )
          if [[ -n $run_default_args ]]; then
            tmux set-environment -t "$selected_name" RUN_DEFAULT_ARGS "$run_default_args"
          fi
        else
          echo "No RUN_COMMAND exported."
        fi
    fi

    # Prefer .claude at the repo root (or selected dir if not in a repo).
    claude_check_dir="${repo_root:-$selected}"
    if [[ -d "$claude_check_dir/.claude" ]]; then
        tmux send-keys -t "$selected_name" "claude" C-m
    elif [[ -n "$repo_root" ]]; then
        tmux send-keys -t "$selected_name" "git fetch && nvim" C-m
    elif [[ "$selected_name" == *data || "$selected_name" == "reports" ]]; then
        tmux send-keys -t "$selected_name" "vd" C-m
    fi
fi

if [[ -z "$TMUX" ]]; then
    tmux a -t "$selected_name"
else
    tmux switch-client -t "$selected_name"
fi
