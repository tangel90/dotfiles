#!/usr/bin/env zsh

PREFIX="$HOME/.password-store/"
EXT=".gpg"

vault_item=$(fd . $PREFIX --extension=$EXT | sed -e "s:$PREFIX::gi" -e "s:$EXT::gi" | fzf --select-1)
[[ -z $vault_item ]] && { echo "No vault item selected"; exit 1; }

if [[ -z $1 ]]; then
  pass -c -- "$vault_item"
else
  content=$(pass -- "$vault_item") || exit $?
  NVIM_APPNAME=nvim-scratchpad nvim - <<< "$content"
fi
